# Пример переменных окружения

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/realty_db

# Пул соединений
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT - ВАЖНО: замените на свой секретный ключ!
# Генерируйте: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=ваш-секретный-ключ-минимум-32-символа-используйте-openssl-rand
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Администратор (опционально)
ADMIN_EMAIL=admin@example.com
